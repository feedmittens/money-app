# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# PostgreSQL connection string
DATABASE_URL=postgres://tally:yourpassword@localhost:5432/tally

# Random string used to sign session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Set to 'production' when deploying behind nginx/SSL
NODE_ENV=development

# Email address that gets auto-approved as admin on first registration
ADMIN_EMAIL=you@example.com

# Public URL of the app (used for OAuth redirect URIs)
APP_URL=https://your-domain.example.com

# Google OAuth credentials (optional — only needed if using Google sign-in)
# Create at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API server port (default: 3001)
# PORT=3001
